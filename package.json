{
  "name": "@giselles-ai/sandbox-volume",
  "version": "0.1.0",
  "description": "Transactional workspace synchronization for @vercel/sandbox.",
  "keywords": [
    "blob",
    "sandbox",
    "storage",
    "sync",
    "vercel",
    "workspace"
  ],
  "homepage": "https://github.com/giselles-ai/sandbox-volume#readme",
  "bugs": {
    "url": "https://github.com/giselles-ai/sandbox-volume/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/giselles-ai/sandbox-volume.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@vercel/blob": "2.3.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "@types/node": "25.5.0",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@vercel/sandbox": "1.8.1"
  }
}
